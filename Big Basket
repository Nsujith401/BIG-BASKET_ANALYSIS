DROP TABLE IF EXISTS bigbasket;

CREATE TABLE bigbasket (
    productid INTEGER,
    product VARCHAR(255) NOT NULL,
    category VARCHAR(150),
    "sub category" VARCHAR(150),
    brand VARCHAR(120),
    saleprice NUMERIC(8,2),
    marketprice NUMERIC(8,2),
    rating NUMERIC(3,2),
    description TEXT
);

-- =========================================
-- DATA EXPLORATION
-- =========================================

-- 1. Count of rows
SELECT COUNT(*) FROM bigbasket;

-- 2. View sample data
SELECT * FROM bigbasket
LIMIT 10;

-- 3. Check for NULL values
SELECT * FROM bigbasket
WHERE product IS NULL
OR category IS NULL
OR "sub category" IS NULL
OR brand IS NULL
OR saleprice IS NULL
OR marketprice IS NULL
OR rating IS NULL;

-- 4. List different product categories
SELECT DISTINCT category
FROM bigbasket
ORDER BY category;

-- 5. Number of products per category
SELECT category, COUNT(*) AS total_products
FROM bigbasket
GROUP BY category
ORDER BY total_products DESC;

-- 6. Products appearing multiple times
SELECT product, COUNT(*) AS number_of_entries
FROM bigbasket
GROUP BY product
HAVING COUNT(*) > 1
ORDER BY number_of_entries DESC;

-- =========================================
-- DATA CLEANING
-- =========================================

-- 7. Products with zero price
SELECT * FROM bigbasket
WHERE saleprice = 0 OR marketprice = 0;

-- 8. Delete products where marketprice = 0
DELETE FROM bigbasket
WHERE marketprice = 0;

-- 9. Add discount percentage column
ALTER TABLE bigbasket
ADD COLUMN discount_percent NUMERIC(5,2);

-- 10. Update discount percentage
UPDATE bigbasket
SET discount_percent =
ROUND(((marketprice - saleprice) / marketprice) * 100, 2);

-- View discount results
SELECT product, marketprice, saleprice, discount_percent
FROM bigbasket;

-- =========================================
-- DATA ANALYSIS QUESTIONS
-- =========================================

-- Q1. Top 10 best-value products based on discount percentage
SELECT product, marketprice, saleprice, discount_percent
FROM bigbasket
ORDER BY discount_percent DESC
LIMIT 10;

-- Q2. Products with high market price (>500) but low rating (<3)
SELECT product, marketprice, rating
FROM bigbasket
WHERE marketprice > 500 AND rating < 3
ORDER BY marketprice DESC;

-- Q3. Calculate estimated revenue per category
SELECT category,
SUM(saleprice) AS total_revenue
FROM bigbasket
GROUP BY category
ORDER BY total_revenue DESC;

-- Q4. Products where market price > 1000 and discount < 5%
SELECT product, marketprice, discount_percent
FROM bigbasket
WHERE marketprice > 1000 AND discount_percent < 5
ORDER BY marketprice DESC;

-- Q5. Top 5 categories with highest average discount
SELECT category,
ROUND(AVG(discount_percent),2) AS avg_discount
FROM bigbasket
GROUP BY category
ORDER BY avg_discount DESC
LIMIT 5;

-- Q6. Best-rated products (rating >= 4.5)
SELECT product, rating
FROM bigbasket
WHERE rating >= 4.5
ORDER BY rating DESC;

-- Q7. Categorize products by price range
SELECT product, saleprice,
CASE 
    WHEN saleprice < 100 THEN 'Budget'
    WHEN saleprice < 500 THEN 'Standard'
    ELSE 'Premium'
END AS price_category
FROM bigbasket;

-- Q8. Total number of products per brand
SELECT brand,
COUNT(*) AS total_products
FROM bigbasket
GROUP BY brand
ORDER BY total_products DESC;

-- Q9. Rank products by highest sale price within each category
SELECT product, category, saleprice,
RANK() OVER (PARTITION BY category ORDER BY saleprice DESC) AS price_rank
FROM bigbasket;

-- Q10. Top 5 highest profit margin products
SELECT product,
(marketprice - saleprice) AS profit_margin
FROM bigbasket
ORDER BY profit_margin DESC
LIMIT 5;
